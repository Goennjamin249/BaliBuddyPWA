# BaliBuddy PWA - Environment Variables Template
# Copy this file to .env and fill in your API keys

# ExchangeRate-API (for live currency rates)
# Get your free API key at: https://www.exchangerate-api.com/
EXPO_PUBLIC_API_KEY_EXCHANGE_RATE=43a909fcad112796aeaf81d2

# BMKG Weather API (Indonesian Meteorological Agency)
# Available at: https://data.bmkg.go.id/
EXPO_PUBLIC_API_KEY_BMKG=yhttps://api.bmkg.go.id/publik/prakiraan-cuaca?adm4=31.71.01.1001

# MAGMA Volcano API (Indonesian Volcanology)
# Available at: https://magma.esdm.go.id/
EXPO_PUBLIC_API_KEY_MAGMA=your_magma_api_key_here

# AIS Vessel Tracking API (for ferry tracker)
# Options: MarineTraffic, VesselFinder, or AISHub
EXPO_PUBLIC_API_KEY_AIS=your_ais_api_key_here

# Mapbox (optional, for enhanced map features)
# Get your token at: https://www.mapbox.com/
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiZ29lbm5qYW1pbiIsImEiOiJjbW40djU4ZDkwMHJoMnNzNnRlanliMXoyIn0.qMUR9VGXLEHJ1aCU2iwlMg

# Google Maps (optional alternative)
# Get your key at: https://console.cloud.google.com/
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key_here

# App Configuration
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_VERSION=1.0.0

# Offline Data Refresh Intervals (in minutes)
EXPO_PUBLIC_CURRENCY_REFRESH_INTERVAL=60
EXPO_PUBLIC_WEATHER_REFRESH_INTERVAL=30
EXPO_PUBLIC_VOLCANO_REFRESH_INTERVAL=15

# Feature Flags
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_LOCATION_SERVICES=true
EXPO_PUBLIC_ENABLE_CAMERA_SCANNER=true